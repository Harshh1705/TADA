# tada configuration
# Copy this file to .env and fill in your values.
# tada also reads from ~/.FolioPy/config.env (shared with FolioPy).
# Priority order: .env > ~/.FolioPy/config.env > environment variables.

# LLM Provider (required)
# Options: groq (https://console.groq.com) or openrouter (https://openrouter.ai)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_api_key_here

# Optional: override the default model
# Groq default: llama-3.3-70b-versatile
# OpenRouter default: google/gemini-2.0-flash-exp:free
# LLM_MODEL=

# Tavily Search API (optional, strongly recommended for better results)
# Sign up: https://tavily.com
# TAVILY_API_KEY=tvly_your_key_here

# FolioPy Supabase (optional, enables cross-reference with portfolio monitor)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=eyJ_your_supabase_key_here
